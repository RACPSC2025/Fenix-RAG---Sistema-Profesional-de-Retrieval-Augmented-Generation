# ─── Entorno ──────────────────────────────────────────────────────────────────
APP_ENV=development          # development | testing | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
ROOT_DIR=.                   # raíz del proyecto (absoluto o relativo)

# ─── AWS Bedrock ──────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=           # opcional — solo para credenciales temporales

# Modelos Bedrock (cambiar aquí sin tocar código)
BEDROCK_LLM_MODEL=amazon.nova-pro-v1:0
BEDROCK_LLM_LARGE_CTX_MODEL=amazon.nova-lite-v1:0
BEDROCK_EMBEDDINGS_MODEL=amazon.titan-embed-text-v2:0

# ─── LLM Parámetros ───────────────────────────────────────────────────────────
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096
LLM_MAX_TOKENS_LARGE=8192

# ─── Ingestion ────────────────────────────────────────────────────────────────
# Chunking
CHUNK_SIZE=1100
CHUNK_OVERLAP=220

# OCR
OCR_LANGUAGES=es,en          # lista separada por comas
OCR_MIN_DPI=150              # DPI mínimo para considerar imagen procesable
OCR_GPU=false                # true si hay GPU disponible

# Umbral de calidad PDF: ratio de chars/páginas bajo = PDF escaneado
PDF_TEXT_QUALITY_THRESHOLD=50

# LlamaParse (opcional — solo si usas ese loader)
LLAMA_PARSE_API_KEY=

# Docling — número máximo de workers para conversión paralela
DOCLING_NUM_WORKERS=2

# ─── Vector Store (Chroma) ────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./storage/chroma
CHROMA_COLLECTION_NAME=fenix_legal

# ─── Base de datos relacional ─────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/fenix_rag
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─── Retrieval ────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=10
RETRIEVAL_RERANK_TOP_K=5
BM25_CACHE_DIR=./storage/bm25_cache
FLASHRANK_MODEL=ms-marco-MiniLM-L-12-v2
FLASHRANK_CACHE_DIR=./storage/models

# ─── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1